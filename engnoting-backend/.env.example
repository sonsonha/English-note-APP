# Database
DATABASE_URL=postgres://user:password@localhost:5432/english_noting?sslmode=disable

# Server
PORT=8080

# AI Provider (openai | gemini | deepseek)
AI_PROVIDER=gemini
AI_API_KEY=your-api-key-here

# JWT — generate two different random secrets (e.g. openssl rand -hex 32)
JWT_SECRET_CURRENT=your-current-jwt-secret
JWT_SECRET_PREVIOUS=your-previous-jwt-secret
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_MINUTES=1440

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
